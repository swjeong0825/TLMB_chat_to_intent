# LLM provider to use: groq | openai | google
LLM_PROVIDER=groq

# --- Groq (set when LLM_PROVIDER=groq) ---
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (set when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (set when LLM_PROVIDER=google) ---
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-2.0-flash

# External backend base URL
BACKEND_BASE_URL=https://tlmbbackendmain-production.up.railway.app

# --- E2E Test credentials ---
# TEST_LEAGUE_ID=<uuid of a freshly created league>
# TEST_HOST_TOKEN=<host_token returned when the league was created>
# The test suite seeds all required match/player/team data automatically.

# --- Rate limiting (slowapi, in-memory) ---
# RATELIMIT_ENABLED=true
# RATELIMIT_DEFAULT=60/minute
# RATELIMIT_CHAT_ROUTE=30/minute
# RATELIMIT_HEADERS=false
