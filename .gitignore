.env
.env.local
.env.*.local

# Virtual environment
.venv/
venv/
env/

# Python bytecode & caches
__pycache__/
*.py[cod]
*$py.class

# Pytest cache
.pytest_cache/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Coverage reports
.coverage
htmlcov/
coverage.xml

# MyPy / type checker cache
.mypy_cache/
.dmypy.json

# Ruff / linter caches
.ruff_cache/

# Local HTTP client environment files (may contain real credentials)
http-client.env.json
http-client.private.env.json

# macOS metadata
.DS_Store

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

commands.txt